---
permalink: /api/corpus.json
sitemap: false
---
{
  "generated_at": {{ site.time | date_to_xmlschema | jsonify }},
  "site": {
    "title": {{ site.title | jsonify }},
    "description": {{ site.description | jsonify }},
    "url": {{ site.url | append: site.baseurl | jsonify }}
  },
  "qualifying": {{ site.data.qualifying | jsonify }},
  "posts": [
    {%- assign sorted = site.posts | sort: "date" | reverse -%}
    {%- for post in sorted -%}
    {
      "title": {{ post.title | jsonify }},
      "subtitle": {{ post.subtitle | jsonify }},
      "url": {{ post.url | prepend: site.baseurl | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }},
      "categories": {{ post.categories | jsonify }},
      "country_code": {{ post.country_code | jsonify }},
      "content": {{ post.content | strip_html | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
